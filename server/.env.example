PORT=8080
NODE_ENV=development
MONGO_URI=mongodb://root:secret@mongo:27017/virallens?authSource=admin
JWT_SECRET=<JWT_SECRET>
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
AI_MODEL=liquid/lfm-2.5-1.2b-instruct:free

#  CORS 
CORS_ORIGIN=http://localhost:4173

# Global limiter
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # requests per window

# Chat-specific limiter
CHAT_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
CHAT_RATE_LIMIT_MAX=20           # messages per minute
